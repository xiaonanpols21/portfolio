<!DOCTYPE html>
<html lang="nl">
<%- include('../partials/head'); %>
<body>
    <header class="home-header">
        <h1 class="visually-hidden">Xiao Nan Portfolio</h1>
        <nav class="nav-logo">
            <div>
                <a href="index.html"><img src="img/logo.svg" alt="logo"></a>
            </div>
        </nav>
        <nav class="head-nav">
            <ul>
                <li><a href="#about"><i class="fa-solid fa-user"></i>About me</a></li>
                <li><a href="#skills"><i class="fa-solid fa-code"></i>Skills</a></li>
                <li><a href="#"><i class="fa-solid fa-paintbrush"></i>My work</a></li>
                <li><a href="#"><i class="fa-solid fa-laptop"></i>Experiences</a></li>
                <li><a href="#"><i class="fa-solid fa-envelope"></i>Contact</a></li>
            </ul>
        </nav>
        <header class="sticky-header">
            <div>
                <a href="index.html"><img src="img/logo.svg" alt="logo"></a>
                <nav id="menu-bars">
                    <i class="fa-solid fa-bars"></i>
                    <ul>
                        <li><a href="#about">About me</a></li>
                        <li><a href="#skills">Skills</a></li>
                        <li><a href="#">My work</a></li>
                        <li><a href="#">Experiences</a></li>
